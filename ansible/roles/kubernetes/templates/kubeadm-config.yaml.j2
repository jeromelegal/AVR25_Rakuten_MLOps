apiVersion: kubeadm.k8s.io/v1beta4
kind: InitConfiguration
nodeRegistration:
  criSocket: unix:///var/run/containerd/containerd.sock
  imagePullPolicy: IfNotPresent
  name: "{{ kubeadm_control_plane_endpoint }}"
  taints: []
localAPIEndpoint:
  advertiseAddress: {{ kubeadm_advertise_address }}
  bindPort: 6443
bootstrapTokens:
- groups:
  - system:bootstrappers:kubeadm:default-node-token
  token: abcdef.0123456789abcdef
  ttl: 24h0m0s
  usages:
  - signing
  - authentication
---
apiVersion: kubeadm.k8s.io/v1beta4
kind: ClusterConfiguration
kubernetesVersion: {{ kubeadm_version | default('1.34.0') }}
controlPlaneEndpoint: "{{ kubeadm_control_plane_endpoint }}:6443"
networking:
  dnsDomain: cluster.local
  serviceSubnet: {{ kubernetes_service_subnet | default('10.96.0.0/12') }}
  podSubnet: {{ kubeadm_pod_subnet | default('10.244.0.0/16') }}
apiServer:
  certSANs:
  - "{{ kubeadm_control_plane_endpoint }}"
  - "{{ kubeadm_advertise_address }}"
  - "127.0.0.1"
{% for master in groups['masters'] %}
  - "{{ hostvars[master].get('ansible_default_ipv4', {}).get('address', hostvars[master].get('ansible_host', '127.0.0.1')) }}"
{% endfor %}
